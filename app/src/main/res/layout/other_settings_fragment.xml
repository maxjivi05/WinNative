<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/window_background_color_dark">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls"
        android:scrollbarThumbVertical="@drawable/nav_scrollbar_thumb"
        android:scrollbarSize="2dp"
        android:scrollbarStyle="insideInset"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="16dp"
            android:paddingTop="16dp"
            android:paddingRight="16dp"
            android:paddingBottom="20dp">

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/ic_components"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_check_for_updates" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_check_for_updates_summary" />
                </LinearLayout>

                <Button
                    android:id="@+id/BTCheckForUpdate"
                    style="@style/OtherSettingsInlineButton"
                    android:layout_marginEnd="8dp"
                    android:text="Check" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBCheckForUpdates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/settings_general_refresh_rate" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/content_icon_surface"
                        android:padding="10dp"
                        android:src="@drawable/icon_monitor"
                        app:tint="@color/settings_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsCardTitle"
                            android:text="@string/settings_general_refresh_rate" />

                        <TextView
                            style="@style/OtherSettingsCardSummary"
                            android:text="@string/settings_general_refresh_rate_summary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/content_asset_row_surface"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="8dp">

                    <Spinner
                        android:id="@+id/SRefreshRate"
                        style="@style/OtherSettingsSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/settings_audio_sound" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/content_icon_surface"
                        android:padding="10dp"
                        android:src="@drawable/ic_other"
                        app:tint="@color/settings_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsCardTitle"
                            android:text="@string/settings_audio_midi_sound_font" />

                        <TextView
                            style="@style/OtherSettingsCardSummary"
                            android:text="@string/settings_audio_summary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/content_asset_row_surface"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="8dp">

                    <Spinner
                        android:id="@+id/SMIDISoundFont"
                        style="@style/OtherSettingsSpinner"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1" />

                    <ImageButton
                        android:id="@+id/BTInstallSF"
                        style="@style/OtherSettingsIconButton"
                        android:contentDescription="@string/common_ui_add"
                        android:src="@drawable/ic_content_add" />

                    <ImageButton
                        android:id="@+id/BTRemoveSF"
                        style="@style/OtherSettingsIconButton"
                        android:layout_marginStart="6dp"
                        android:contentDescription="@string/common_ui_remove"
                        android:src="@drawable/ic_content_menu_remove" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/settings_general_paths_title" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/content_icon_surface"
                        android:padding="10dp"
                        android:src="@drawable/icon_open"
                        app:tint="@color/settings_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsCardTitle"
                            android:text="@string/settings_general_paths_title" />

                        <TextView
                            style="@style/OtherSettingsCardSummary"
                            android:text="@string/settings_general_paths_summary" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/content_asset_row_surface"
                    android:gravity="center_vertical"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsFieldLabel"
                            android:text="@string/settings_general_winlator_path_title" />

                        <TextView
                            android:id="@+id/TVWinlatorPath"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/inter"
                            android:maxLines="3"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/BTChooseWinlatorPath"
                        style="@style/OtherSettingsInlineButton"
                        android:layout_marginStart="10dp"
                        android:text="@string/settings_general_choose_path" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/content_asset_row_surface"
                    android:gravity="center_vertical"
                    android:minHeight="54dp"
                    android:orientation="horizontal"
                    android:paddingLeft="10dp"
                    android:paddingTop="8dp"
                    android:paddingRight="8dp"
                    android:paddingBottom="8dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsFieldLabel"
                            android:text="@string/settings_general_shortcut_export_path_title" />

                        <TextView
                            android:id="@+id/TVShortcutExportPath"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="@font/inter"
                            android:maxLines="3"
                            android:textColor="@color/settings_text_primary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/BTChooseShortcutExportPath"
                        style="@style/OtherSettingsInlineButton"
                        android:layout_marginStart="10dp"
                        android:text="@string/settings_general_choose_path" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/session_xserver_title" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/content_icon_surface"
                        android:padding="10dp"
                        android:src="@drawable/icon_monitor"
                        app:tint="@color/settings_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsCardTitle"
                            android:text="@string/settings_general_cursor_speed" />

                        <TextView
                            style="@style/OtherSettingsCardSummary"
                            android:text="@string/settings_general_xserver_cursor_summary" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/TVCursorSpeed"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/settings_text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <SeekBar
                    android:id="@+id/SBCursorSpeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:background="@null"
                    android:max="200"
                    android:min="10"
                    android:progressBackgroundTint="@color/settings_outline"
                    android:progressTint="@color/settings_accent"
                    android:splitTrack="false"
                    android:thumbTint="@color/settings_accent" />
            </LinearLayout>

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/ic_x11_icon"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/session_xserver_use_dri3_extension" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/session_xserver_use_dri3_description" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBUseDRI3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/icon_gamepad"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_cursor_lock_title" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_cursor_lock_summary" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBCursorLock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/icon_keyboard"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_xinput_toggle_title" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_xinput_toggle_summary" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBXinputToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/settings_content_components" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/ic_components"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_enable_file_provider" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_file_provider_summary" />
                </LinearLayout>

                <ImageButton
                    android:id="@+id/BTHelpFileProvider"
                    style="@style/OtherSettingsIconButton"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/settings_general_help_file_provider"
                    android:src="@drawable/icon_help" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBEnableFileProvider"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/ic_components"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_open_with_android_browser" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_open_browser_summary" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBOpenWithAndroidBrowser"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:gravity="center_vertical"
                android:minHeight="72dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginEnd="14dp"
                    android:background="@drawable/content_icon_surface"
                    android:padding="10dp"
                    android:src="@drawable/ic_components"
                    app:tint="@color/settings_icon_tint" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        style="@style/OtherSettingsCardTitle"
                        android:text="@string/settings_general_share_android_clipboard" />

                    <TextView
                        style="@style/OtherSettingsCardSummary"
                        android:text="@string/settings_general_clipboard_summary" />
                </LinearLayout>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBShareAndroidClipboard"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <TextView
                style="@style/OtherSettingsSectionLabel"
                android:text="@string/settings_general_imagefs" />

            <LinearLayout
                style="@style/OtherSettingsCard"
                android:layout_marginBottom="24dp"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="14dp"
                        android:background="@drawable/content_icon_surface"
                        android:padding="10dp"
                        android:src="@drawable/ic_reinstall"
                        app:tint="@color/settings_icon_tint" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            style="@style/OtherSettingsCardTitle"
                            android:text="@string/settings_general_reinstall_imagefs" />

                        <TextView
                            style="@style/OtherSettingsCardSummary"
                            android:text="@string/settings_general_imagefs_summary" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/BTReInstallImagefs"
                    style="@style/OtherSettingsInlineButton"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="10dp"
                    android:text="@string/settings_general_reinstall_imagefs" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</FrameLayout>
