<?xml version="1.0" encoding="utf-8"?>
<!-- Base dialog chrome for components warnings, confirmations, and embedded content views. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/content_dialog_surface"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="14dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:id="@+id/LLTitleBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:minHeight="34dp"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/IVIcon"
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="8dp"
                app:tint="@color/settings_icon_tint"
                android:visibility="gone" />

            <TextView
                android:id="@+id/TVTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/inter"
                android:letterSpacing="0.01"
                android:textColor="@color/settings_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="10dp"
            android:background="@color/settings_outline" />
    </LinearLayout>

    <TextView
        android:id="@+id/TVMessage"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:fontFamily="@font/inter"
        android:layout_marginBottom="6dp"
        android:lineSpacingExtra="3dp"
        android:textColor="@color/settings_text_secondary"
        android:textSize="13sp"
        android:visibility="gone" />

    <EditText
        style="@style/OtherSettingsEditText"
        android:id="@+id/EditText"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="2dp"
        android:visibility="gone" />

    <ListView
        android:id="@+id/ListView"
        android:layout_width="340dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/FrameLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/LLBottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="vertical">

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="10dp"
            android:background="@color/settings_outline" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical|end"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/TVBottomBarText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/inter"
                android:textColor="@color/settings_text_secondary"
                android:textStyle="bold"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/LLBottomBarPanel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:visibility="gone" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@id/BTReset"
                    android:visibility="gone"
                    android:text="@string/common_ui_reset"
                    style="@style/ContentDialogButtonNeutral" />

                <Button
                    style="@style/ContentDialogButtonNeutral"
                    android:text="@string/common_ui_cancel"
                    android:id="@+id/BTCancel" />

                <Button
                    style="@style/ContentDialogButtonPositive"
                    android:layout_marginStart="10dp"
                    android:text="@string/common_ui_ok"
                    android:id="@+id/BTConfirm" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>