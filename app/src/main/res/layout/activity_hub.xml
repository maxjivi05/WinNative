<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F1015"
    android:id="@+id/main_root">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:layout_gravity="top"
        android:background="#1C1D24"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_store_icon"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_launcher_foreground"
            android:tint="#FFFFFF"
            android:contentDescription="@string/common_ui_store" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/tab_library"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/common_ui_library"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true"/>

            <TextView
                android:id="@+id/tab_store"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/common_ui_store"
                android:textColor="#888888"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true"/>

            <TextView
                android:id="@+id/tab_downloads"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/common_ui_downloads"
                android:textColor="#888888"
                android:textSize="18sp"
                android:textStyle="bold"
                android:paddingHorizontal="16dp"
                android:background="?android:attr/selectableItemBackground"
                android:focusable="true"
                android:clickable="true"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btn_settings"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@android:drawable/ic_menu_preferences"
            android:tint="#FFFFFF"
            android:contentDescription="@string/common_ui_settings"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:clickable="true"/>

    </LinearLayout>

    <!-- Content Area -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="64dp">

        <!-- Library View -->
        <FrameLayout
            android:id="@+id/view_library"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="visible">
            
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_library"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                android:scrollbars="none" />
                
            <TextView
                android:id="@+id/tv_empty_library"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/library_games_no_games_hub"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:gravity="center"
                android:visibility="gone"
                android:background="?android:attr/selectableItemBackground"
                android:padding="24dp"
                android:focusable="true"
                android:clickable="true"/>
        </FrameLayout>

        <!-- Store View -->
        <FrameLayout
            android:id="@+id/view_store"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_store"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="16dp"
                android:clipToPadding="false"
                android:scrollbars="none" />
        </FrameLayout>

        <!-- Downloads View -->
        <FrameLayout
            android:id="@+id/view_downloads"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Wave Background Placeholder (Implemented in code or simple shape) -->
            <com.winlator.cmod.ui.WaveView
                android:id="@+id/wave_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:padding="32dp"
                android:background="#88000000"
                android:layout_margin="32dp"
                android:elevation="8dp">

                <!-- Game Artwork -->
                <ImageView
                    android:layout_width="120dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_launcher_foreground"
                    android:background="#333333"
                    android:scaleType="centerCrop" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:paddingStart="24dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Downloading: Cyberpunk 2077 (Mock)"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <ProgressBar
                        android:id="@+id/download_progress"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent"
                        android:layout_height="24dp"
                        android:layout_marginTop="16dp"
                        android:progress="65"
                        android:progressDrawable="@drawable/progress_drawable" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Speed: 45.2 MB/s"
                            android:textColor="#AAAAAA"
                            android:textSize="16sp" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="45 GB / 70 GB (65%)"
                            android:textColor="#AAAAAA"
                            android:textSize="16sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </FrameLayout>
    </FrameLayout>
</FrameLayout>
