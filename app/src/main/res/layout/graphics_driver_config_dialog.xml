<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="288dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="4dp">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="320dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp">

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:text="@string/container_graphics_vulkan_version" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverVulkanVersion"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/vulkan_version_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_version" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverVersion"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_available_extensions" />

            <com.winlator.cmod.widget.MultiSelectionComboBox
                android:id="@+id/MSCAvailableExtensions"
                style="@style/OtherSettingsMultiSelectComboBox"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_wine_gpu_name" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverGPUName"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_max_device_memory" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverMaxDeviceMemory"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/device_memory_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_present_modes" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverPresentMode"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/present_mode_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_resource_type" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverResourceType"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/resource_type_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_bcn_emulation" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverBCnEmulation"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/bcn_emulation_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_bcn_emulation_type" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverBCnEmulationType"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/bcn_emulation_type_entries"
                android:spinnerMode="dropdown" />

            <TextView
                style="@style/OtherSettingsFieldLabel"
                android:layout_marginTop="10dp"
                android:text="@string/container_graphics_bcn_emulation_cache" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/SGraphicsDriverBCnEmulationCache"
                style="@style/OtherSettingsSpinner"
                android:layout_width="match_parent"
                android:layout_marginTop="4dp"
                android:entries="@array/bcn_emulation_cache_entries"
                android:spinnerMode="dropdown" />

            <!-- Toggles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/env_vars_row_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:text="@string/container_graphics_sync_frame"
                    android:textColor="@color/settings_text_primary"
                    android:textSize="13sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBSyncFrame"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:background="@drawable/env_vars_row_background"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingHorizontal="10dp"
                android:paddingVertical="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="@font/inter"
                    android:text="@string/container_graphics_disable_present_wait"
                    android:textColor="@color/settings_text_primary"
                    android:textSize="13sp" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/CBDisablePresentWait"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    app:thumbTint="@color/settings_accent"
                    app:trackTintMode="src_in" />
            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
