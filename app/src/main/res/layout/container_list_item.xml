<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="138dp"
    android:background="@drawable/content_list_card_surface"
    android:orientation="vertical"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/ImageView"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/content_icon_surface"
            android:padding="8dp"
            android:src="@drawable/ic_containers"
            app:tint="@color/settings_icon_tint" />

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <ImageButton
            android:id="@+id/BTDuplicate"
            style="@style/OtherSettingsIconButton"
            android:layout_marginEnd="8dp"
            android:contentDescription="@string/common_ui_duplicate"
            android:src="@drawable/ic_controls_duplicate" />

        <ImageButton
            android:id="@+id/BTMenu"
            style="@style/OtherSettingsIconButton"
            android:contentDescription="@string/common_ui_edit"
            android:src="@drawable/icon_list_item_menu" />
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/TVTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:ellipsize="end"
            android:fontFamily="@font/inter"
            android:gravity="center"
            android:maxLines="2"
            android:textColor="@color/settings_text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/BTRun"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/content_action_button_background"
            android:contentDescription="@string/common_ui_run"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/icon_play"
            app:tint="@color/settings_accent" />

        <ImageButton
            android:id="@+id/BTEdit"
            android:layout_width="0dp"
            android:layout_height="34dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/content_action_button_background"
            android:contentDescription="@string/common_ui_edit"
            android:padding="7dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_controls_edit"
            app:tint="@color/settings_icon_tint" />
    </LinearLayout>

</LinearLayout>
