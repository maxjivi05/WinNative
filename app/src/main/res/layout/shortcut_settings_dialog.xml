<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/LLShortcutSettingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#111111">

    <!-- ============ LEFT SIDEBAR ============ -->
    <LinearLayout
        android:layout_width="180dp"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@drawable/nav_sidebar_bg">

        <!-- Scrollable section buttons -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/LLSidebarItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingTop="12dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:paddingBottom="8dp">

                <!-- Section: General -->
                <LinearLayout
                    android:id="@+id/BTSectionGeneral"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_other"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_general_title"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Display -->
                <LinearLayout
                    android:id="@+id/BTSectionDisplay"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/icon_monitor"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/session_display_title"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Audio -->
                <LinearLayout
                    android:id="@+id/BTSectionAudio"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_other"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_audio_sound"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Wine -->
                <LinearLayout
                    android:id="@+id/BTSectionWine"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_containers"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/container_wine_title"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Components -->
                <LinearLayout
                    android:id="@+id/BTSectionComponents"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_components"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/settings_content_components"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Variables -->
                <LinearLayout
                    android:id="@+id/BTSectionVariables"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_presets"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/container_config_variables"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Input -->
                <LinearLayout
                    android:id="@+id/BTSectionInput"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/ic_input_controls"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/common_ui_input_controls"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

                <!-- Section: Advanced -->
                <LinearLayout
                    android:id="@+id/BTSectionAdvanced"
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:gravity="center_vertical"
                    android:paddingStart="14dp"
                    android:paddingEnd="14dp"
                    android:layout_marginBottom="2dp"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:clickable="true">
                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:src="@drawable/icon_settings"
                        app:tint="#B0BEC5"
                        android:scaleType="centerInside" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="@string/common_ui_advanced"
                        android:textColor="#B0BEC5"
                        android:textSize="14sp"
                        android:fontFamily="@font/inter"
                        android:letterSpacing="0.02" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- Divider above bottom buttons -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/nav_header_divider" />

        <!-- Bottom: Confirm button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <Button
                android:id="@+id/BTSidebarConfirm"
                style="@style/ContentDialogButtonPositive"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:text="@string/common_ui_ok" />
        </LinearLayout>
    </LinearLayout>

    <!-- Edge divider between sidebar and content -->
    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="@drawable/nav_edge_divider" />

    <!-- ============ RIGHT CONTENT AREA ============ -->
    <ScrollView
        android:id="@+id/SVContent"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:scrollbarThumbVertical="@drawable/nav_scrollbar_thumb"
        android:scrollbarSize="2dp"
        android:scrollbars="vertical">

        <LinearLayout
            android:id="@+id/LLContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <!-- ======== SECTION: General ======== -->
            <LinearLayout
                android:id="@+id/LLSectionGeneral"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_ui_name" />

                <EditText
                    style="@style/EditText"
                    android:id="@+id/ETName"
                    android:inputType="textCapSentences" />

                <Button
                    style="@style/ButtonNeutral"
                    android:id="@+id/BTAddToHomeScreen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="@string/shortcuts_list_add_to_home_screen" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/container_config_screen_size" />

                        <Spinner
                            style="@style/ComboBox"
                            android:layout_width="match_parent"
                            android:id="@+id/SScreenSize"
                            android:entries="@array/screen_size_entries"
                            android:spinnerMode="dialog" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/LLCustomScreenSize"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/common_ui_width" />
                            <EditText
                                style="@style/EditText"
                                android:layout_width="78dp"
                                android:id="@+id/ETScreenWidth"
                                android:inputType="number" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textStyle="bold"
                            android:textSize="18dp"
                            android:layout_gravity="bottom"
                            android:layout_marginLeft="2dp"
                            android:layout_marginRight="2dp"
                            android:layout_marginBottom="4dp"
                            android:text="x" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/common_ui_height" />
                            <EditText
                                style="@style/EditText"
                                android:layout_width="78dp"
                                android:id="@+id/ETScreenHeight"
                                android:inputType="number" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/TVRefreshRateLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_general_refresh_rate" />

                <Spinner
                    style="@style/ComboBox"
                    android:layout_width="match_parent"
                    android:id="@+id/SRefreshRate" />
            </LinearLayout>

            <!-- ======== SECTION: Display ======== -->
            <LinearLayout
                android:id="@+id/LLSectionDisplay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/container_graphics_driver" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Spinner
                        style="@style/ComboBox"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:id="@+id/SGraphicsDriver"
                        android:entries="@array/graphics_driver_entries" />
                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTGraphicsDriverConfig"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="8dp"
                        android:src="@drawable/icon_settings" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/TVWrapperVersionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/common_ui_current_version_label"
                        android:textStyle="bold"
                        android:paddingRight="8dp" />
                    <TextView
                        android:id="@+id/TVGraphicsDriverVersion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="default_version"
                        android:textColor="@android:color/holo_blue_dark" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/container_wine_dxwrapper"
                        android:paddingTop="8dp" />
                    <ImageView
                        android:id="@+id/BTHelpDXWrapper"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:layout_marginLeft="4dp"
                        android:src="@drawable/icon_help"
                        app:tint="#e0e0e0" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <Spinner
                        style="@style/ComboBox"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:id="@+id/SDXWrapper"
                        android:entries="@array/dxwrapper_entries"
                        android:spinnerMode="dialog" />
                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTDXWrapperConfig"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:padding="8dp"
                        android:src="@drawable/icon_settings" />
                </LinearLayout>
            </LinearLayout>

            <!-- ======== SECTION: Audio ======== -->
            <LinearLayout
                android:id="@+id/LLSectionAudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/container_config_audio_driver" />
                <Spinner
                    style="@style/ComboBox"
                    android:layout_width="match_parent"
                    android:id="@+id/SAudioDriver"
                    android:entries="@array/audio_driver_entries" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/settings_audio_midi_sound_font" />
                <Spinner
                    style="@style/ComboBox"
                    android:layout_width="match_parent"
                    android:id="@+id/SMIDISoundFont" />
            </LinearLayout>

            <!-- ======== SECTION: Wine ======== -->
            <LinearLayout
                android:id="@+id/LLSectionWine"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:id="@+id/LLEmulator">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/container_config_emulator_64bit" />
                    <Spinner
                        style="@style/ComboBox"
                        android:layout_width="match_parent"
                        android:id="@+id/SEmulator64"
                        android:entries="@array/emulator_entries"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/container_config_dll_emulator" />
                    <Spinner
                        style="@style/ComboBox"
                        android:layout_width="match_parent"
                        android:id="@+id/SEmulator"
                        android:entries="@array/emulator_entries"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/container_config_lc_all" />
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <EditText
                        style="@style/AppTheme"
                        android:layout_gravity="center"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:id="@+id/ETlcall" />
                    <ImageButton
                        style="@style/ListMenuButton"
                        android:id="@+id/BTShowLCALL"
                        android:layout_gravity="center"
                        android:src="@drawable/icon_more_vert" />
                </LinearLayout>
            </LinearLayout>

            <!-- ======== SECTION: Components ======== -->
            <LinearLayout
                android:id="@+id/LLSectionComponents"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Keep IDs LLTabWinComponents so Java code still finds it -->
                <LinearLayout
                    android:id="@+id/LLTabWinComponents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            style="@style/FieldSet"
                            android:id="@+id/LLWinComponentsDirectX" />
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/container_wine_directx" />
                    </FrameLayout>
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <LinearLayout
                            style="@style/FieldSet"
                            android:id="@+id/LLWinComponentsGeneral" />
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/settings_general_title" />
                    </FrameLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ======== SECTION: Variables ======== -->
            <LinearLayout
                android:id="@+id/LLSectionVariables"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Keep ID LLTabEnvVars so Java code still finds it -->
                <LinearLayout
                    android:id="@+id/LLTabEnvVars"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/TVEnvVarsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/container_config_env_vars" />

                    <com.winlator.cmod.widget.EnvVarsView
                        android:id="@+id/EnvVarsView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"/>

                    <View style="@style/HorizontalLine" />

                    <Button
                        style="@style/ButtonNeutral"
                        android:id="@+id/BTAddEnvVar"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:text="@string/common_ui_add" />
                </LinearLayout>
            </LinearLayout>

            <!-- ======== SECTION: Input ======== -->
            <LinearLayout
                android:id="@+id/LLSectionInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <LinearLayout style="@style/FieldSet">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/common_ui_profile" />
                        <Spinner
                            style="@style/ComboBox"
                            android:id="@+id/SControlsProfile"
                            android:layout_width="match_parent"
                            android:spinnerMode="dialog" />
                        <CheckBox
                            android:id="@+id/CBDisabledXInput"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/shortcuts_properties_disable_xinput" />
                        <CheckBox
                            android:id="@+id/CBTouchscreenMode"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/session_xserver_simulate_touch_screen" />
                    </LinearLayout>
                    <TextView
                        style="@style/FieldSetLabel"
                        android:background="#ffffff"
                        android:text="@string/common_ui_input_controls" />
                </FrameLayout>

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp">
                    <LinearLayout style="@style/FieldSet">
                        <LinearLayout
                            android:id="@+id/LLDinputMapperType"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_config_directinput_mapper_type" />
                            <Spinner
                                style="@style/ComboBox"
                                android:id="@+id/SDInputType"
                                android:layout_width="match_parent"
                                android:entries="@array/dinput_mapper_type_entries" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <CheckBox
                                android:id="@+id/CBEnableXInput"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:text="@string/container_config_enable_xinput" />
                            <ImageView
                                android:id="@+id/BTXInputHelp"
                                style="@style/HelpButton"
                                android:layout_gravity="center" />
                        </LinearLayout>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginTop="8dp">
                            <CheckBox
                                android:id="@+id/CBEnableDInput"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_config_enable_dinput" />
                            <ImageView
                                android:id="@+id/BTDInputHelp"
                                style="@style/HelpButton"
                                android:layout_gravity="center" />
                        </LinearLayout>
                    </LinearLayout>
                    <TextView
                        style="@style/FieldSetLabel"
                        android:background="#ffffff"
                        android:text="@string/session_gamepad_game_controller" />
                </FrameLayout>
            </LinearLayout>

            <!-- ======== SECTION: Advanced ======== -->
            <LinearLayout
                android:id="@+id/LLSectionAdvanced"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <!-- Keep ID LLTabAdvanced so Java code still finds it -->
                <LinearLayout
                    android:id="@+id/LLTabAdvanced"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/box64Frame"
                        android:layout_marginTop="8dp">
                        <LinearLayout style="@style/FieldSet">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_box64_version" />
                            <Spinner
                                style="@style/ComboBox"
                                android:id="@+id/SBox64Version"
                                android:layout_width="match_parent"
                                android:entries="@array/box64_version_entries"
                                android:spinnerMode="dialog" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_box64_preset" />
                            <Spinner
                                style="@style/ComboBox"
                                android:id="@+id/SBox64Preset"
                                android:layout_width="match_parent" />
                        </LinearLayout>
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/container_box64_title" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:id="@+id/fexcoreFrame"
                        android:layout_marginTop="8dp">
                        <LinearLayout style="@style/FieldSet">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_fexcore_version" />
                            <Spinner
                                style="@style/ComboBox"
                                android:id="@+id/SFEXCoreVersion"
                                android:layout_width="match_parent" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_fexcore_preset" />
                            <Spinner
                                style="@style/ComboBox"
                                android:id="@+id/SFEXCorePreset"
                                android:layout_width="match_parent" />
                        </LinearLayout>
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/container_fexcore_config" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <LinearLayout style="@style/FieldSet">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_config_startup_selection" />
                            <Spinner
                                style="@style/ComboBox"
                                android:layout_width="match_parent"
                                android:id="@+id/SStartupSelection"
                                android:entries="@array/startup_selection_entries" />
                        </LinearLayout>
                        <TextView
                            android:id="@+id/TVSystem"
                            style="@style/FieldSetLabel"
                            android:text="@string/common_ui_system" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <LinearLayout style="@style/FieldSet">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/shortcuts_properties_exec_arguments" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">
                                <EditText
                                    style="@style/EditText"
                                    android:layout_width="0dp"
                                    android:layout_weight="1"
                                    android:id="@+id/ETExecArgs" />
                                <ImageButton
                                    style="@style/ListMenuButton"
                                    android:id="@+id/BTExtraArgsMenu"
                                    android:src="@drawable/icon_more_vert" />
                            </LinearLayout>
                            <CheckBox
                                android:id="@+id/CBFullscreenStretched"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/session_display_fullscreen_stretched" />
                        </LinearLayout>
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/common_ui_system" />
                    </FrameLayout>

                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp">
                        <LinearLayout style="@style/FieldSet">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/container_graphics_vkbasalt_sharpness_effects" />
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical">
                                <Spinner
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:id="@+id/SSharpnessEffect"
                                    style="@style/ComboBox"
                                    android:entries="@array/vkbasalt_sharpness_entries"
                                    android:spinnerMode="dialog" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/container_graphics_vkbasalt_sharpness_level" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:id="@+id/TVSharpnessLevel" />
                                </LinearLayout>
                                <SeekBar
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:min="0"
                                    android:id="@+id/SBSharpnessLevel"
                                    android:max="100" />
                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="horizontal">
                                    <TextView
                                        android:layout_width="0dp"
                                        android:layout_height="wrap_content"
                                        android:layout_weight="1"
                                        android:text="@string/container_graphics_vkbasalt_sharpness_denoise" />
                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_gravity="end"
                                        android:gravity="end"
                                        android:layout_height="wrap_content"
                                        android:id="@+id/TVSharpnessDenoise" />
                                </LinearLayout>
                                <SeekBar
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:min="0"
                                    android:id="@+id/SBSharpnessDenoise"
                                    android:max="100" />
                            </LinearLayout>
                        </LinearLayout>
                        <TextView
                            style="@style/FieldSetLabel"
                            android:background="#ffffff"
                            android:text="@string/container_graphics_vkbasalt" />
                    </FrameLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/container_config_processor_affinity"
                        android:layout_marginTop="8dp" />

                    <com.winlator.cmod.widget.CPUListView
                        android:id="@+id/CPUListView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_horizontal"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
